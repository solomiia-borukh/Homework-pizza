# Supabase Postgres connection string (Drizzle)
# Supabase dashboard → Project Settings → Database → Connection string (URI).
DATABASE_URL="postgresql://[USER]:[PASSWORD]@[HOST]:[PORT]/postgres"

# Better Auth — generate a secret of at least 32 characters
BETTER_AUTH_SECRET="replace-with-a-32+-char-random-secret"
BETTER_AUTH_URL="http://localhost:3000"

# Google OAuth — Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""